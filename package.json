{
  "name": "opencode-chat",
  "displayName": "OpenCode Chat",
  "description": "AI-powered chat interface for opencode in VS Code:",
  "version": "0.1.0",
  "publisher": "divergent",
  "repository": {
    "type": "git",
    "url": "https://github.com/divergentD/OpenCode-VSCode"
  },
  "license": "MIT",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#000000",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.94.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:opencode.chat"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "opencode",
          "title": "opencode",
          "icon": "./images/mark.svg"
        }
      ],
      "auxiliarybar": [
        {
          "id": "opencode-changes",
          "title": "Changes",
          "icon": "./images/mark.svg"
        }
      ]
    },
    "views": {
      "opencode": [
        {
          "id": "opencode.chat",
          "type": "webview",
          "name": "Chat"
        }
      ],
      "opencode-changes": [
        {
          "id": "opencode.fileChanges",
          "type": "webview",
          "name": "Changes"
        }
      ]
    },
    "commands": [
      {
        "command": "opencode.newSession",
        "title": "opencode: New Session"
      },
      {
        "command": "opencode.focus",
        "title": "opencode: Focus Chat"
      },
      {
        "command": "opencode.attachSelection",
        "title": "opencode: Attach Selection"
      },
      {
        "command": "opencode.showFileChanges",
        "title": "opencode: Show File Changes",
        "icon": "$(diff)"
      }
    ],
    "keybindings": [
      {
        "command": "opencode.focus",
        "key": "cmd+shift+o",
        "mac": "cmd+shift+o",
        "win": "ctrl+shift+o",
        "linux": "ctrl+shift+o"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.js",
    "build:extension": "node esbuild.js --target=extension",
    "build:webview": "node esbuild.js --target=webview",
    "watch": "node esbuild.js --watch",
    "watch:extension": "node esbuild.js --watch --target=extension",
    "watch:webview": "node esbuild.js --watch --target=webview",
    "package": "node esbuild.js --production",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:run": "vitest run"
  },
  "devDependencies": {
    "@types/dompurify": "^3",
    "@types/node": "22.13.9",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/vscode": "^1.94.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@vscode/test-cli": "^0.0.12",
    "esbuild": "^0.25.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@opencode-ai/sdk": "1.14.26",
    "diff": "^9.0.0",
    "dompurify": "^3",
    "marked": "^14",
    "react": "^18",
    "react-diff-view": "^3.3.3",
    "react-dom": "^18",
    "refractor": "^3.6.0"
  }
}
